{
  "name": "typst-mcp",
  "version": "0.1.0",
  "description": "MCP server for agent-driven Typst/LaTeX document authoring — compile, navigate, edit, review, and register research documents",
  "type": "module",
  "bin": {
    "typst-mcp": "./bin/typst-mcp.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "mcp",
    "typst",
    "latex",
    "research",
    "documents",
    "agent",
    "ai",
    "llm",
    "academic",
    "model-context-protocol"
  ],
  "license": "MIT",
  "author": "Kairo Intelligence Technologies",
  "repository": {
    "type": "git",
    "url": "https://github.com/edward-lcl/typst-mcp"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.0"
  }
}
